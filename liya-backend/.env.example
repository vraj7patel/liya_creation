# Liya Backend Environment Variables
# Copy to .env and fill in your values

# MongoDB (use MongoDB Atlas for production)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/liya-creation?retryWrites=true&w=majority

# Session (generate strong secret)
SESSION_SECRET=your-super-secret-session-key-here-min-32-chars

# Stripe (optional, for payments)
STRIPE_SECRET_KEY=sk_test_...

# Email (optional, for notifications)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Production
NODE_ENV=production
PORT=10000  # Render assigns this

# Google OAuth (if used)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
